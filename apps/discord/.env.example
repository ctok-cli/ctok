# Required - from https://discord.com/developers/applications → your app → Bot
DISCORD_TOKEN=your-bot-token

# Required - from OAuth2 → General → Client ID
DISCORD_CLIENT_ID=your-client-id

# Optional - for guild-scoped command deployment (instant propagation)
# From the server you want to test in: Server Settings → Widget → Server ID
DISCORD_GUILD_ID=your-guild-id

# Optional - NODE_ENV
NODE_ENV=development
