# Required — from https://api.slack.com/apps → your app → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Required — from Basic Information → App Credentials
SLACK_SIGNING_SECRET=your-signing-secret

# Optional — only needed for Socket Mode (no public URL required)
# From Basic Information → App-Level Tokens → generate with connections:write scope
SLACK_APP_TOKEN=xapp-your-app-level-token

# Optional — HTTP port when NOT using Socket Mode (default: 3000)
PORT=3000

# Optional — set to "production" to reduce log noise
NODE_ENV=development
