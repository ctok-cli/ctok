{
  "name": "@ctok/browser-ext",
  "version": "0.1.0",
  "description": "Chrome MV3 browser extension - live token overlay on claude.ai, chatgpt.com, cursor.sh, deepseek, gemini",
  "private": true,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "node scripts/package.mjs"
  },
  "dependencies": {
    "@ctok/core": "workspace:*",
    "@ctok/refiner": "workspace:*",
    "preact": "^10.25.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.324",
    "@types/node": "^22.19.19",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
