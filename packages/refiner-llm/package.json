{
  "name": "@ctok/refiner-llm",
  "version": "0.1.0",
  "description": "LLM-powered prompt refiner for ctok - uses Claude via the Anthropic API",
  "license": "MIT",
  "author": "ctok contributors",
  "homepage": "https://github.com/ctok-cli/ctok#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctok-cli/ctok.git",
    "directory": "packages/refiner-llm"
  },
  "bugs": {
    "url": "https://github.com/ctok-cli/ctok/issues"
  },
  "keywords": [
    "claude",
    "prompt",
    "refiner",
    "ai-sdk",
    "vercel-ai-gateway"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ai": "^4.3.0",
    "@ai-sdk/anthropic": "^1.2.0",
    "@ctok/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "@ai-sdk/anthropic": "^1.2.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    }
  }
}
